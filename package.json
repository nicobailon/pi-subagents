{
  "name": "pi-subagents-http",
  "version": "0.25.0",
  "description": "Pi extension for delegating tasks to remote agents over HTTP",
  "author": "Nico Bailon",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicobailon/pi-subagents.git"
  },
  "homepage": "https://github.com/nicobailon/pi-subagents#readme",
  "bugs": {
    "url": "https://github.com/nicobailon/pi-subagents/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "subagents",
    "ai",
    "agents",
    "cli"
  ],
  "files": [
    "src/**/*.ts",
    "skills/**/*",
    "README.md"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test test/unit/*.test.ts"
  },
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-agent-core": {
      "optional": true
    },
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.74.0",
    "eventsource-parser": "^3.0.0",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0"
  }
}
